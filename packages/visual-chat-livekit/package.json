{
  "name": "@proj-airi/visual-chat-livekit",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "LiveKit transport adapter for AIRI visual chat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/moeru-ai/airi.git",
    "directory": "packages/visual-chat-livekit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "README.md",
    "dist",
    "package.json"
  ],
  "scripts": {
    "dev": "pnpm run build",
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@livekit/rtc-node": "^0.13.24",
    "@proj-airi/visual-chat-observability": "workspace:^",
    "@proj-airi/visual-chat-protocol": "workspace:^",
    "@proj-airi/visual-chat-shared": "workspace:^",
    "livekit-server-sdk": "^2.13.0"
  }
}
