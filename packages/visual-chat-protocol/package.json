{
  "name": "@proj-airi/visual-chat-protocol",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "Protocol definitions, schemas, and event constants for AIRI visual chat",
  "license": "MIT",
  "repository": {
    "type": "git",
