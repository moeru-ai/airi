{
  "name": "@proj-airi/volc-realtime",
  "type": "module",
  "private": true,
  "description": "Volcengine Realtime Dialogue WebSocket protocol client for Project AIRI",
  "author": {
    "name": "Moeru AI Project AIRI Team",
    "email": "airi@moeru.ai",
    "url": "https://github.com/moeru-ai"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
