{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default AIRI permissions for the main Tauri window.",
  "windows": [
    "main",
    "settings",
    "chat",
    "widgets",
    "widgets-*",
    "caption",
    "notice",
    "notice-*",
    "about",
    "onboarding",
    "devtools",
    "devtools-*",
    "beat-sync",
    "inlay",
    "dashboard",
    "plugins"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "sidecars/plugin-host",
          "sidecar": true,
          "args": [
            {
              "validator": "\\S+"
            }
          ]
        }
      ]
    },
    "store:default"
  ]
}
