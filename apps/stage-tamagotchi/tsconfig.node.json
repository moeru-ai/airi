{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "jsx": "preserve",
    "lib": [
      "ESNext"
    ],
    "useDefineForClassFields": true,
    "paths": {
      "@proj-airi/visual-chat-ops": [
        "../../packages/visual-chat-ops/src/index.ts"
      ],
      "@proj-airi/visual-chat-shared": [
        "../../packages/visual-chat-shared/src/index.ts"
      ],
      "@proj-airi/visual-chat-shared/*": [
        "../../packages/visual-chat-shared/src/*"
      ]
    },
    "resolveJsonModule": true,
    "types": [
      "vitest",
      "vite/client",
      "electron-vite/node",
      "unplugin-info/client"
    ],
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "../../uno.config.ts",
    "../../packages/visual-chat-ops/src/**/*.ts",
    "../../packages/visual-chat-shared/src/**/*.ts",
    "uno.config.ts",
    "electron.vite.config.ts",

    "src/main/**/*.ts",
    "src/main/**/*.d.ts",
    "src/main/**/*.tsx",
    "src/main/**/*.vue",

    "src/shared/**/*.ts",
    "src/shared/**/*.d.ts",
    "src/shared/**/*.tsx",
    "src/shared/**/*.vue"
  ]
}
