  "homepage": "https://airi.moeru.ai/",
  "license": "MIT",
  "architecture": {
    "64bit": {
      "url": "https://github.com/moeru-ai/airi/releases/download/v0.9.0-alpha.12/AIRI-0.9.0-alpha.12-windows-x64-setup.exe#/dl.7z",
