# All variables below are optional unless you need to override auto-detection.

WORKER_PORT=6201
VISUAL_CHAT_GATEWAY_URL=http://127.0.0.1:6200
VISUAL_CHAT_WORKER_PROFILE=auto
LOG_LEVEL=info

# Native MiniCPM-o bridge profile
MINICPMO_NATIVE_GATEWAY_URL=http://127.0.0.1:8006
MINICPMO_NATIVE_MODEL=openbmb/MiniCPM-o-4_5

# 16GB-friendly local lite profile via Ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=openbmb/minicpm-v4.5:latest
