# Discord credentials
DISCORD_COMPANION_TOKEN=
DISCORD_COMPANION_CLIENT_ID=

# AIRI server connection
AIRI_URL=ws://localhost:6121/ws
AIRI_TOKEN=

# Optional: comma separated text channel IDs to listen on in addition to the voice channel attached chat.
# DISCORD_COMPANION_TEXT_CHANNEL_IDS=

# Whether to respond only when bot is mentioned or in DM for text messages.
# Default: true
# DISCORD_COMPANION_TEXT_MENTION_ONLY=true

# Optional: auto-join a voice channel on ready (guildId:channelId).
# DISCORD_COMPANION_AUTO_JOIN=

# Speech-to-text (OpenAI compatible endpoint, e.g. faster-whisper service)
OPENAI_STT_API_BASE_URL=http://localhost:8090/v1/
OPENAI_STT_API_KEY=sk-local
OPENAI_STT_MODEL=whisper-1
