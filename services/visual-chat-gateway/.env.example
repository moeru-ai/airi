# All variables below are optional; defaults match local LiveKit dev and the worker on localhost.

VISUAL_CHAT_PORT=6200

# Default: ws://localhost:7880
LIVEKIT_URL=ws://localhost:7880

# Default: devkey
LIVEKIT_API_KEY=devkey

# Default: secret
LIVEKIT_API_SECRET=secret

# Default: http://localhost:6201
WORKER_URL=http://localhost:6201

LOG_LEVEL=debug
