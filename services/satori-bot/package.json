    "drizzle-orm": "catalog:",
    "es-toolkit": "catalog:es-toolkit-1-45-1",
    "nanoid": "catalog:nanoid-5-1-9",
    "valibot": "catalog:valibot-1-3-1",
    "ws": "catalog:"
  },
  "devDependencies": {
    "@types/ws": "catalog:",
    "drizzle-kit": "catalog:"
  }
